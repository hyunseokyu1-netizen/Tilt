{
  "expo": {
    "name": "Tilt",
    "slug": "tilt",
    "owner": "hyunseokyu1-netizen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tilt",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1622"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hyunseokyu.tilt"
    },
    "android": {
      "backgroundColor": "#0B1622",
      "package": "com.hyunseokyu.tilt",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B1622"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
